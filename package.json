{
  "name": "schedule-bot",
  "version": "1.0.0",
  "description": "🤖 Personal Telegram AI assistant with task scheduling, long-term memory, voice transcription, and intelligent reminders.",
  "long_description": "Dudoserr is a sophisticated Telegram bot that acts as your personal AI assistant. It manages your daily tasks, remembers important information, provides intelligent reminders based on your schedule, and processes voice messages. Built with TypeScript, it uses OpenRouter/Groq/OpenAI for AI, SQLite for storage, and Mem0 for long-term memory.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "db:init": "npm run build && node dist/db/bootstrap.js",
    "db:verify-tools": "npm run build && node dist/db/verify-tools.js",
    "memory:clean-test": "npm run build && node dist/memory/clean-test-memory.js",
    "memory:verify": "npm run build && node dist/memory/verify-memory.js",
    "telegram:verify-text-schedule": "npm run build && node dist/telegram/verify-text-schedule.js",
    "voice:verify": "npm run build && node dist/telegram/verify-voice.js",
    "test": "echo \"No tests configured\""
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "assistant",
    "task-management",
    "scheduling",
    "memory",
    "voice",
    "transcription",
    "openai",
    "llm",
    "typescript",
    "node.js"
  ],
  "author": "Umalanif <your-email@example.com>",
  "homepage": "https://github.com/Umalanif/Schedule-bot",
  "repository": {
    "type": "git",
    "url": "https://github.com/Umalanif/Schedule-bot.git"
  },
  "bugs": {
    "url": "https://github.com/Umalanif/Schedule-bot/issues"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "mem0ai": "^3.0.3",
    "node-cron": "^4.2.1",
    "openai": "^6.37.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  }
}
