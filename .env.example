# ============================================
# TELEGRAM CONFIGURATION
# ============================================

# Telegram Bot Token (from @BotFather)
# Get it at: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (integer)
# Get it at: https://t.me/userinfobot
TELEGRAM_OWNER_ID=123456789

# ============================================
# AI PROVIDER CONFIGURATION
# Choose ONE provider below
# ============================================

# Provider type: openrouter | groq | openai
AI_PROVIDER=openrouter

# OpenRouter API Key (RECOMMENDED)
# Sign up: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# Groq API Key (fast inference)
# Sign up: https://groq.com/groqcloud/
# GROQ_API_KEY=gsk_your_groq_key_here

# OpenAI API Key (premium quality)
# Sign up: https://platform.openai.com/
# Requires payment method!
# OPENAI_API_KEY=sk-proj-your_openai_key_here

# ============================================
# MEMORY CONFIGURATION (Mem0)
# ============================================

# Mem0 API Key (for long-term memory)
# Sign up: https://mem0.ai/
MEM0_API_KEY=your_mem0_api_key_here

# Mem0 API Base URL
MEM0_API_BASE=https://api.mem0.ai/v1

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database file path (optional, defaults to ./data/bot.db)
# DATABASE_PATH=./data/bot.db

# ============================================
# OTHER CONFIGURATION
# ============================================

# Timezone for scheduling
# TIMEZONE=Europe/Moscow

# Log level: debug | info | warn | error
# LOG_LEVEL=info

# ============================================
# NOTES
# ============================================

# 1. Never commit this file to Git
# 2. Keep your API keys secret - do not share them
# 3. For setup instructions, see SETUP.md
# 4. For more details, see README.md
